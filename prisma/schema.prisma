generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model Prompt {
  id          String    @id @default(cuid())
  title       String
  description String    @default("")
  content     String
  category    String    @default("general")
  model       String    @default("universal")
  status      String    @default("inbox")
  qualityScore Float?
  isFavorite  Boolean   @default(false)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  tags     PromptTag[]
  versions PromptVersion[]
  history  AgentHistory[]
}

model Tag {
  id      String      @id @default(cuid())
  name    String      @unique
  prompts PromptTag[]
  modules ModuleTag[]
}

model PromptTag {
  promptId String
  tagId    String
  prompt   Prompt @relation(fields: [promptId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([promptId, tagId])
}

model Module {
  id        String      @id @default(cuid())
  title     String
  content   String
  type      String      @default("role")
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  tags ModuleTag[]
}

model ModuleTag {
  moduleId String
  tagId    String
  module   Module @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  tag      Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([moduleId, tagId])
}

model PromptVersion {
  id            String   @id @default(cuid())
  promptId      String
  versionNumber Int
  title         String
  content       String
  snapshot      String   @default("{}")
  createdAt     DateTime @default(now())
  prompt        Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

model AgentHistory {
  id         String   @id @default(cuid())
  promptId   String
  type       String   @default("react_trajectory")
  input      String   @default("")
  output     String   @default("{}")
  trajectory String   @default("[]")
  provider   String   @default("minimax")
  model      String   @default("MiniMax-M2.7")
  createdAt  DateTime @default(now())
  prompt     Prompt   @relation(fields: [promptId], references: [id], onDelete: Cascade)
}

model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

model AgentProfile {
  id        String   @id @default(cuid())
  key       String   @unique
  content   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive])
}

model MemoryEvent {
  id              String    @id @default(cuid())
  eventType       String
  triggerType     String
  sourcePromptId  String?
  content         String
  extractedMemory String?
  metadata        String    @default("{}")
  status          String    @default("pending")
  contentHash     String    @unique
  processedAt     DateTime?
  retryCount      Int       @default(0)
  errorMessage    String?
  createdAt       DateTime  @default(now())

  @@index([status, createdAt])
  @@index([sourcePromptId])
  @@index([eventType, triggerType])
}

model SemanticMemory {
  id              String    @id @default(cuid())
  content         String
  embedding       Bytes
  embeddingModel  String
  dimensions      Int
  type            String
  source          String    @default("learned")
  confidence      Float     @default(0.8)
  sourcePromptId  String?
  triggerType     String?
  lastValidatedAt DateTime?
  supersedesId    String?
  supersededById  String?
  reason          String?
  eventId         String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  decayAt         DateTime?

  @@index([type, confidence])
  @@index([sourcePromptId])
  @@index([eventId])
  @@index([supersededById])
  @@index([decayAt])
}

model UsageLog {
  id           String   @id @default(cuid())
  service      String
  provider     String
  model        String?
  inputTokens  Int?
  outputTokens Int?
  requestCount Int      @default(1)
  success      Boolean  @default(true)
  errorCode    String?
  createdAt    DateTime @default(now())

  @@index([service, createdAt])
  @@index([provider, createdAt])
}

model Alert {
  id             String   @id @default(cuid())
  type           String
  severity       String
  message        String
  metadata       String   @default("{}")
  acknowledged   Boolean  @default(false)
  acknowledgedAt DateTime?
  createdAt      DateTime @default(now())

  @@index([acknowledged, createdAt])
  @@index([type, createdAt])
}
